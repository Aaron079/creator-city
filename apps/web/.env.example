# Creator City — 自有模型 endpoint 配置
#
# CREATOR_MODEL_MODE=local
#   不调用远程模型，使用 Creator City 本地规则回答（default）
#
# CREATOR_MODEL_MODE=remote
#   调用 CREATOR_MODEL_ENDPOINT 指向的自有模型服务
#
# CREATOR_MODEL_ENDPOINT
#   你自己的模型推理服务地址（仅 remote mode 使用）
#   示例：https://your-model-gateway.example.com/v1/chat
#
# CREATOR_MODEL_API_KEY
#   你的模型网关 key，只在服务端读取，严禁暴露给浏览器
#   不要使用 NEXT_PUBLIC_CREATOR_MODEL_API_KEY
#   不要提交真实 key 到 git
#
# CREATOR_MODEL_NAME
#   模型名称标识（显示用，不影响路由逻辑）
#
# CREATOR_MODEL_TIMEOUT_MS
#   远程调用超时时间（毫秒），默认 20000

CREATOR_MODEL_MODE=local
CREATOR_MODEL_ENDPOINT=
CREATOR_MODEL_API_KEY=
CREATOR_MODEL_NAME=creator-city-local
CREATOR_MODEL_TIMEOUT_MS=20000
