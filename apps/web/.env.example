# Creator City — 环境变量配置模板
#
# 真实 key 只放 .env.local 或 Vercel Environment Variables。
# 不要使用 NEXT_PUBLIC_* 存储任何 provider key。
# 不要提交真实 key 到 git。
# 修改 Vercel 环境变量后必须重新部署。

# ==================================================
# Database — 用户系统必须配置
# ==================================================
# PostgreSQL 连接字符串。本地开发: docker compose up -d postgres
# Vercel 生产: 建议使用 Vercel Postgres 或 Supabase

DATABASE_URL=

# ==================================================
# Authentication — 用户注册/登录/session
# ==================================================
# AUTH_SESSION_SECRET: 任意长随机字符串，用于签名。生产环境必须修改。
#   生成: openssl rand -hex 32
# AUTH_COOKIE_NAME: session cookie 名，默认 creator_city_session
# AUTH_SESSION_DAYS: session 有效天数，默认 30 天
# AUTH_ADMIN_EMAILS: 逗号分隔，注册时自动设为 ADMIN 角色

AUTH_SESSION_SECRET=
AUTH_COOKIE_NAME=creator_city_session
AUTH_SESSION_DAYS=30
AUTH_ADMIN_EMAILS=

# ==================================================
# Creator City Agent — 自有模型 endpoint
# ==================================================
#
# CREATOR_MODEL_MODE=local   不调用远程模型，使用本地规则回答（default）
# CREATOR_MODEL_MODE=remote  调用 CREATOR_MODEL_ENDPOINT 指向的自有模型服务

CREATOR_MODEL_MODE=local
CREATOR_MODEL_ENDPOINT=
CREATOR_MODEL_API_KEY=
CREATOR_MODEL_NAME=creator-city-local
CREATOR_MODEL_TIMEOUT_MS=20000

# ==================================================
# Provider Gateway
# ==================================================

PROVIDER_GATEWAY_MODE=real
PROVIDER_DEFAULT_TIMEOUT_MS=30000

# ==================================================
# App / Billing
# ==================================================
# All third-party payment secrets are server-side only.
# Do not use NEXT_PUBLIC_* for secrets. Stripe publishable key is the only public payment key.
# Alipay / WeChat Pay / Stripe / Paddle env changes require redeploy.
# Missing keys make the payment method show not-configured. No fake payments.

APP_URL=http://localhost:3000
BILLING_DEFAULT_REGION=CN
BILLING_DEFAULT_CURRENCY=CNY

# Manual recharge mode
MANUAL_RECHARGE_ENABLED=true

# Alipay
ALIPAY_ENABLED=false
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_GATEWAY_URL=
ALIPAY_NOTIFY_URL=

# WeChat Pay API v3
WECHAT_PAY_ENABLED=false
WECHAT_PAY_MCH_ID=
WECHAT_PAY_APP_ID=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_PRIVATE_KEY=
WECHAT_PAY_CERT_SERIAL_NO=
WECHAT_PAY_PLATFORM_PUBLIC_KEY=
WECHAT_PAY_NOTIFY_URL=

# Stripe
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Paddle
PADDLE_ENABLED=false
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_ENVIRONMENT=sandbox

# Credits / Pricing
USD_CNY_RATE=7.2
CREDIT_INTERNAL_CNY_VALUE=0.05
PROVIDER_COST_MULTIPLIER=1.8

# ==================================================
# Internal API secret — Next.js server → NestJS server
# ==================================================
# Must match INTERNAL_API_SECRET in apps/server/.env
# Used for freeze/settle/refund credit calls from generate routes.
# Generate with: openssl rand -hex 32

INTERNAL_API_SECRET=

# ==================================================
# Public template media search
# ==================================================
# PEXELS_API_KEY / PIXABAY_API_KEY 用于合法公开素材搜索。
# 未配置时使用本地占位，不会下载或存储外部素材。

PEXELS_API_KEY=
PIXABAY_API_KEY=

# ==================================================
# OpenAI — text generation + image generation
# ==================================================
# Required for: GPT-5 (text), OpenAI GPT Images (image)

OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4o
OPENAI_IMAGE_MODEL=dall-e-3

# ==================================================
# Anthropic — Claude text generation
# ==================================================
# Required for: Claude (text-script)

ANTHROPIC_API_KEY=

# ==================================================
# Runway — video generation
# ==================================================
# Official API: https://app.runwayml.com → Settings → API
# Required for: Runway (video generation, gen4_turbo)

RUNWAY_API_KEY=

# ==================================================
# ElevenLabs — voice / TTS
# ==================================================
# Official API: https://elevenlabs.io → Profile → API Key
# Required for: ElevenLabs (voice-dubbing)

ELEVENLABS_API_KEY=

# ==================================================
# Replicate — generic model bridge
# ==================================================

REPLICATE_API_TOKEN=

# ==================================================
# Stability AI — image / audio
# ==================================================

STABILITY_API_KEY=

# ==================================================
# Creator City custom video provider (自有视频生成网关)
# ==================================================
# CUSTOM_VIDEO_PROVIDER_ENDPOINT 是你自己的视频生成网关地址
# 设置后 Creator Video Gateway 自动标记 available，可真实生成视频
# CUSTOM_VIDEO_PROVIDER_API_KEY 只在服务端读取，不要使用 NEXT_PUBLIC_*
# 没有 endpoint 时，视频生成不会真实调用，只显示 not-configured

CUSTOM_VIDEO_PROVIDER_ENDPOINT=
CUSTOM_VIDEO_PROVIDER_API_KEY=
CUSTOM_VIDEO_PROVIDER_NAME=Creator Video Gateway
CUSTOM_VIDEO_PROVIDER_TIMEOUT_MS=60000

# ==================================================
# Custom provider gateway (user-configured endpoint)
# ==================================================
# Used by the generic-http adapter for bridge-only providers.

CUSTOM_PROVIDER_ENDPOINT=
CUSTOM_PROVIDER_API_KEY=

# ==================================================
# Provider-specific placeholders
# Set endpoint + API key when the provider makes their API available.
# Status will change from not-configured → available automatically.
# ==================================================

KLING_API_KEY=
KLING_API_ENDPOINT=

VIDU_API_KEY=
VIDU_API_ENDPOINT=

SEEDANCE_API_KEY=
SEEDANCE_API_ENDPOINT=

VEO_API_KEY=
VEO_API_ENDPOINT=

SORA_API_KEY=
SORA_API_ENDPOINT=

LUMA_API_KEY=
LUMA_API_ENDPOINT=

PIKA_API_KEY=
PIKA_API_ENDPOINT=

HAILUO_API_KEY=
HAILUO_API_ENDPOINT=

PIXVERSE_API_KEY=
PIXVERSE_API_ENDPOINT=

SUNO_API_KEY=
SUNO_API_ENDPOINT=

UDIO_API_KEY=
UDIO_API_ENDPOINT=

GOOGLE_AI_API_KEY=
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
