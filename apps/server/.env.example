DATABASE_URL="postgresql://postgres:password@localhost:5432/creator_city"
REDIS_HOST=localhost
REDIS_PORT=6379
JWT_SECRET=dev-secret-change-in-production
JWT_EXPIRES_IN=7d
SERVER_PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# ==================================================
# Internal API — server-to-server secret
# ==================================================
# Must match INTERNAL_API_SECRET in the web app env.
# Used by Next.js routes to call /api/v1/credits/internal/* endpoints.
INTERNAL_API_SECRET=change-this-to-a-random-secret
