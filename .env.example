# ─── Database ───────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/creator_city"

# ─── Redis ──────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT ────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# ─── Server ─────────────────────────────────────────
SERVER_PORT=4000
SERVER_HOST=localhost

# ─── Web ────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000

# ─── AI ─────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=sk-ant-...

# ─── Creator City Agent ─────────────────────────────
# OPENAI_API_KEY is read only by server routes. Do not use NEXT_PUBLIC_OPENAI_API_KEY.
# Leave OPENAI_API_KEY empty to use Local Help fallback.
AI_AGENT_PROVIDER=openai
AI_AGENT_MODEL=

# ─── Storage ────────────────────────────────────────
S3_BUCKET=creator-city-assets
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ─── App ────────────────────────────────────────────
NODE_ENV=development
APP_NAME=Creator City
